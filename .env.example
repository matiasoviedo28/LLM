# Puerto del host para Ollama (default Ollama sería 11434)
OLLAMA_PORT=11500

# Puerto del host para Open WebUI (default sería 8080)
WEBUI_PORT=3500

# Dirección IP donde escucharán los servicios.
#
# 127.0.0.1 → SOLO accesible desde esta máquina (DEFAULT, RECOMENDADO)
# 0.0.0.0   → Accesible desde cualquier dispositivo en la red local
#             ⚠️  Solo usar si necesitás acceder desde otra máquina
#             ⚠️  NUNCA usar en redes públicas (cafés, coworkings, wifi abierta)
#             ⚠️  Open WebUI no tiene login por default - cualquiera en la red
#                podría usar tu modelo y leer tus chats
#
# Si cambiás a 0.0.0.0, considerá también activar WEBUI_AUTH=True en docker-compose.yml
BIND_ADDRESS=127.0.0.1

# Modelo a usar con Ollama
#MODEL=gemma3:4b
MODEL=gemma4:e4b
